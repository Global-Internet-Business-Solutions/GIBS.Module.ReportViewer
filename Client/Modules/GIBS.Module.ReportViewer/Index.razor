@using GIBS.Module.ReportViewer.Services
@using GIBS.Module.ReportViewer.Models

@namespace GIBS.Module.ReportViewer
@inherits ModuleBase
@inject IReportViewerService ClientReportViewerService
@inject IStringLocalizer<Index> Localizer

@if (_loading)
{
    <p><em>Loading report...</em></p>
}
else if (_result == null)
{
    <p>No data available.</p>
}
else if (!_result.Success)
{
    <div class="alert alert-warning" role="alert">@_result.ErrorMessage</div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-2">
        <div>
            <strong>Generated:</strong> @_result.GeneratedOnUtc.ToLocalTime().ToString("g")
        </div>
        <button type="button" class="btn btn-secondary" @onclick="RefreshReport">Refresh</button>
    </div>

    @if (_result.ViewMode == ReportViewerSettings.ViewModeTemplate)
    {
        <div>@((MarkupString)(_result.RenderedTemplate ?? string.Empty))</div>
    }
    else
    {
        @if (_result.Rows.Count == 0)
        {
            <p>No rows returned.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-bordered">
                    <thead>
                        <tr>
                            @foreach (var column in _result.Columns)
                            {
                                <th>@column</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _result.Rows)
                        {
                            <tr>
                                @foreach (var column in _result.Columns)
                                {
                                    <td>@(row.TryGetValue(column, out var value) ? value : string.Empty)</td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
}

@code {
    public override string RenderMode => RenderModes.Static;

    public override List<Resource> Resources => new List<Resource>()
    {
        new Stylesheet("_content/GIBS.Module.ReportViewer/Module.css?v=1"),
        new Script("_content/GIBS.Module.ReportViewer/Module.js")
    };

    private bool _loading = true;
    private ReportExecutionResult _result;

    protected override async Task OnInitializedAsync()
    {
        await LoadReport(false);
    }

    private async Task RefreshReport()
    {
        await LoadReport(true);
    }

    private async Task LoadReport(bool bypassCache)
    {
        try
        {
            _loading = true;
            _result = await ClientReportViewerService.ExecuteReportAsync(ModuleState.ModuleId, bypassCache);
            if (_result != null && !_result.Success)
            {
                AddModuleMessage(_result.ErrorMessage, MessageType.Warning);
            }
        }
        catch (Exception ex)
        {
            await logger.LogError(ex, "Error loading report for module {ModuleId}", ModuleState.ModuleId);
            AddModuleMessage("Error loading report.", MessageType.Error);
            _result = new ReportExecutionResult { Success = false, ErrorMessage = "Error loading report." };
        }
        finally
        {
            _loading = false;
        }
    }
}
